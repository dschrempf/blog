#!/usr/bin/env magix
#!magix bash
#!packages hugo

set -e
set +u

# Command line arguments.
# $1: (Optional) Git commit message.

# Current working directory.
CWD=$(pwd)

# A function to be called from within a git repository. Stage, commit all
# changes with optional commit message, and push to the corresponding remote
# repository.
git_push () {
    # Stage all changes.
    git add .
    # If there is a commit message, use it, otherwise use a standard message.
    if [ -n "$1" ]; then
        msg="$1"
    else
        msg="Rebuilding site $(date)."
    fi
    # Commit the changes.
    git commit -m "$msg"
    # Push the changes to the remote repository (origin).
    git push origin master
}

echo "Ensure the published-site submodule (hugo/public) is initialized and healthy."
# 'hugo' writes its output into hugo/public, a git submodule pointing at the
# published-site repo (dschrempf/dschrempf.github.io). If its gitdir pointer is
# missing or broken (e.g. wiped by a stray 'hugo --cleanDestinationDir'), we
# would build into a detached, unpushable working tree. Repair it first.
if [ ! -e hugo/public/.git ]; then
    git submodule deinit -f hugo/public || true
fi
git submodule update --init hugo/public

cd hugo

echo "Remove stale files from the previous build."
# Drop all tracked files in the published site so renamed/fingerprinted assets
# from older builds (e.g. css/skeria.<old-hash>.css) do not linger. We do NOT
# use 'hugo --cleanDestinationDir' here: it would delete the submodule's '.git'
# pointer file. Going through git instead preserves '.git' and any untracked
# files, and the subsequent 'git add .' in git_push stages the removals.
git -C public rm -r -q --ignore-unmatch . || true

echo "Build site with Hugo."
hugo

echo "Push the website built by Hugo to 'dschrempf/blog-html'."
cd public
git_push "$1"

echo "Push the Org Mode source files to 'dschrempf/blog'."
cd "$CWD"
git_push "$1"

echo "Done."
