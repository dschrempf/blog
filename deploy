#!/usr/bin/env magix
#!magix bash
#!packages hugo

set -e
set +u

# Command line arguments.
# $1: (Optional) Git commit message.

# Current working directory.
CWD=$(pwd)

# A function to be called from within a git repository. Stage, commit all
# changes with optional commit message, and push to the corresponding remote
# repository.
git_push () {
    # Stage all changes.
    git add .
    # If there is a commit message, use it, otherwise use a standard message.
    if [ -n "$1" ]; then
        msg="$1"
    else
        msg="Rebuilding site $(date)."
    fi
    # Commit the changes.
    git commit -m "$msg"
    # Push the changes to the remote repository (origin).
    git push origin master
}

echo "Prepare the published-site checkout (hugo/public)."
# 'hugo' writes its output into hugo/public, a git submodule pointing at the
# published-site repo (dschrempf/dschrempf.github.io). The deploy *advances*
# that site, so the submodule MUST sit on the 'master' branch -- not a detached
# HEAD. Commits made on a detached HEAD never move 'master', so the
# 'git push origin master' below would report "up-to-date" and push nothing,
# while the parent repo records the unpublished commit. That mismatch is exactly
# what leaves the submodule "broken" on a fresh clone, so do NOT run
# 'git submodule update' on an existing checkout (it detaches HEAD).

# Initialize only on a fresh clone, where the working tree does not exist yet.
if [ ! -e hugo/public/.git ]; then
    git submodule update --init hugo/public
fi

# Put the checkout on 'master' at exactly the live commit, then empty the
# working tree so stale files from older builds (renamed/fingerprinted assets,
# deleted pages, ...) cannot survive -- hugo regenerates everything from source
# below, and 'git add .' then stages the removals. This is the "re-initialize,
# removing old files" step; we do it via git rather than
# 'hugo --cleanDestinationDir', which would delete the submodule's .git pointer.
# 'rm -r' drops tracked files; 'clean -fdx' drops the untracked leftovers. Both
# leave '.git' untouched.
git -C hugo/public fetch origin master
git -C hugo/public checkout -f -B master origin/master
git -C hugo/public rm -r -q --ignore-unmatch .
git -C hugo/public clean -fdx

cd hugo

echo "Build site with Hugo."
hugo

echo "Push the website built by Hugo to 'dschrempf/blog-html'."
cd public
git_push "$1"

echo "Push the Org Mode source files to 'dschrempf/blog'."
cd "$CWD"
git_push "$1"

echo "Done."
